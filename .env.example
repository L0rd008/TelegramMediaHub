# Bot
BOT_TOKEN=
BOT_MODE=polling
ADMIN_USER_IDS=123456,789012

# Webhook (only for BOT_MODE=webhook)
WEBHOOK_HOST=
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
WEBHOOK_PUBLIC_PORT=443

# Database
DATABASE_URL=postgresql+asyncpg://mediahub:password@localhost:5432/mediahub

# Redis
REDIS_URL=redis://localhost:6379/0

# Performance
GLOBAL_RATE_LIMIT=25
WORKER_COUNT=10

# Logging
LOG_LEVEL=INFO

# Subscription / Trial
TRIAL_DAYS=30

# Optional: Local Bot API Server
# LOCAL_API_URL=http://localhost:8081

# ---------------------------------------------------------------------------
# Runtime config (stored in bot_config DB table, cached in Redis — NOT env vars)
# These can be changed at runtime without restarting the bot.
#
#   allow_paid_broadcast  (default: false)
#     Enables the Bot API 9.6 allow_paid_broadcast flag on all send calls.
#     Toggle via Redis:  SET config:allow_paid_broadcast "true"
#     Or update bot_config table: key="allow_paid_broadcast", value="true"
# ---------------------------------------------------------------------------
